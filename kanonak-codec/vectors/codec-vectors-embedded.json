  "cases": [
    {
      "id": "embedded-named-in-list",
      "description": "A named embedded value ($name = the authored dict-key) inside a list-valued object property. The embedded carries NO type statement — its type is inferred from the property's range and is not materialized in canonical form.",
      "pkg": {
        "publisher": "probe.example.com",
        "packageName": "data",
        "version": "1.0.0",
        "label": "Embedded Probe Data"
      },
      "nodes": [
        {
          "$type": "probe.example.com/schema@1.0.0/Order",
          "$id": "probe.example.com/data@1.0.0/o1",
          "note": "A",
          "items": [
            {
              "$name": "first",
              "sku": "X",
              "qty": 1
            }
          ]
        }
      ],
      "expectedCanonicalForm": "{\"subjects\":[{\"uri\":\"probe.example.com/data@1.0.0/data\",\"statements\":[{\"predicate\":\"kanonak.org/core-rdf@1.1.0/label\",\"type\":\"string\",\"value\":\"Embedded Probe Data\"},{\"predicate\":\"kanonak.org/core-rdf@1.1.0/type\",\"type\":\"ref\",\"value\":\"kanonak.org/core-kanonak@1.0.0/Package\"}]},{\"uri\":\"probe.example.com/data@1.0.0/o1\",\"statements\":[{\"predicate\":\"kanonak.org/core-rdf@1.1.0/type\",\"type\":\"ref\",\"value\":\"probe.example.com/schema@1.0.0/Order\"},{\"predicate\":\"probe.example.com/schema@1.0.0/items\",\"type\":\"list\",\"items\":[{\"type\":\"embedded\",\"name\":\"first\",\"statements\":[{\"predicate\":\"probe.example.com/schema@1.0.0/qty\",\"type\":\"typed\",\"carrier\":\"integer\",\"value\":\"1\"},{\"predicate\":\"probe.example.com/schema@1.0.0/sku\",\"type\":\"typed\",\"carrier\":\"string\",\"value\":\"X\"}]}]},{\"predicate\":\"probe.example.com/schema@1.0.0/note\",\"type\":\"typed\",\"carrier\":\"string\",\"value\":\"A\"}]}]}",
      "expectedHash": "sha256:911547a76ba4ca86cd056a2173b06efb03578bae5ce0fef824c723285a043c1b",
      "expectedSerialize": [
