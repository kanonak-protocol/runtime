{
  "name": "@kanonak-protocol/codec",
  "version": "0.1.0",
  "description": "The generic Kanonak codec runtime: builds the canonical input model from typed nodes + an embedded schema, content-addresses via canonicalHash (kanonak.org/canonical-form), and serializes/deserializes the normalized-JSON wire form. Referenced by generated typed SDKs; pairs with @kanonak-protocol/sdk.",
  "license": "Apache-2.0",
  "homepage": "https://kanonak.org",
  "author": "Kanonak Maintainers (https://github.com/kanonak-protocol/runtime)",
  "bugs": { "url": "https://github.com/kanonak-protocol/runtime/issues" },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "keywords": [
    "kanonak",
    "codec",
    "canonical-form",
    "content-address",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kanonak-protocol/runtime"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kanonak-protocol/sdk": "^4.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
