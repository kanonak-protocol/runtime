{
  "name": "@kanonak-protocol/canonical",
  "version": "0.1.1",
  "description": "The Kanonak canonical form + content hash (canonicalFormVersion \"1\") \u2014 the TypeScript port of kanonak.org/canonical-form, verified byte-for-byte against the shared golden vectors. The identity primitive every generated SDK content-addresses through.",
  "license": "Apache-2.0",
  "homepage": "https://kanonak.org",
  "author": "Kanonak Maintainers (https://github.com/kanonak-protocol/runtime)",
  "bugs": {
    "url": "https://github.com/kanonak-protocol/runtime/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "kanonak",
    "canonical-form",
    "content-address",
    "sha256",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kanonak-protocol/runtime"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "conformance": "tsx src/conformance.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
