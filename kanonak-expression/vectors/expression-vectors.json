{
  "expressionRuntimeVersion": "1",
  "description": "Behavior parity vectors for the Kanonak expression runtime (tx + math). Every language port evaluates these to identical values. `expr` is the tree; `env` binds tx.VarRef names for the conformance resolve hook; `expected` is the numeric result (exact unless `tolerance` is given); `expectError` marks a required runtime error. The determinism traps (Round half-away, floored Modulo, Sign(0)=0, comparisons as 1/0) are required rows.",
  "vectors": [
    { "id": "integer-literal", "expr": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 42 }, "expected": 42 },
    { "id": "decimal-literal", "expr": { "type": "kanonak.org/transformations/DecimalLiteral", "decimalLiteral": 2.5 }, "expected": 2.5 },
    { "id": "boolean-literal-true", "expr": { "type": "kanonak.org/transformations/BooleanLiteral", "booleanLiteral": true }, "expected": 1 },
    { "id": "boolean-literal-false", "expr": { "type": "kanonak.org/transformations/BooleanLiteral", "booleanLiteral": false }, "expected": 0 },

    { "id": "add", "expr": { "type": "kanonak.org/transformations/Add", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 3 } }, "expected": 5 },
    { "id": "subtract", "expr": { "type": "kanonak.org/transformations/Subtract", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 10 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 4 } }, "expected": 6 },
    { "id": "multiply", "expr": { "type": "kanonak.org/transformations/Multiply", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 6 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 7 } }, "expected": 42 },
    { "id": "divide", "expr": { "type": "kanonak.org/transformations/Divide", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 20 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 4 } }, "expected": 5 },
    { "id": "divide-by-zero", "expr": { "type": "kanonak.org/transformations/Divide", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 1 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 0 } }, "expectError": true },

    { "id": "power", "expr": { "type": "kanonak.org/math/Power", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 10 } }, "expected": 1024 },
    { "id": "modulo-floored-negative-dividend", "expr": { "type": "kanonak.org/math/Modulo", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": -7 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 3 } }, "expected": 2 },
    { "id": "modulo-positive", "expr": { "type": "kanonak.org/math/Modulo", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 7 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 3 } }, "expected": 1 },
    { "id": "modulo-floored-negative-divisor", "expr": { "type": "kanonak.org/math/Modulo", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 7 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": -3 } }, "expected": -2 },
    { "id": "modulo-by-zero", "expr": { "type": "kanonak.org/math/Modulo", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 5 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 0 } }, "expectError": true },
    { "id": "minimum", "expr": { "type": "kanonak.org/math/Minimum", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 3 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 8 } }, "expected": 3 },
    { "id": "maximum", "expr": { "type": "kanonak.org/math/Maximum", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 3 }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 8 } }, "expected": 8 },

    { "id": "abs-of-negate", "expr": { "type": "kanonak.org/transformations/Abs", "value": { "type": "kanonak.org/transformations/Negate", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 5 } } }, "expected": 5 },
    { "id": "negate", "expr": { "type": "kanonak.org/transformations/Negate", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 7 } }, "expected": -7 },
    { "id": "exp-0", "expr": { "type": "kanonak.org/math/Exp", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 0 } }, "expected": 1, "tolerance": 1e-9 },
    { "id": "ln-1", "expr": { "type": "kanonak.org/math/Ln", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 1 } }, "expected": 0, "tolerance": 1e-9 },
    { "id": "ln-non-positive", "expr": { "type": "kanonak.org/math/Ln", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 0 } }, "expectError": true },
    { "id": "log10-1000", "expr": { "type": "kanonak.org/math/Log10", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 1000 } }, "expected": 3, "tolerance": 1e-9 },
    { "id": "sqrt-9", "expr": { "type": "kanonak.org/math/Sqrt", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 9 } }, "expected": 3, "tolerance": 1e-9 },
    { "id": "sqrt-negative", "expr": { "type": "kanonak.org/math/Sqrt", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": -4 } }, "expectError": true },
    { "id": "floor", "expr": { "type": "kanonak.org/math/Floor", "value": { "type": "kanonak.org/transformations/DecimalLiteral", "decimalLiteral": 2.7 } }, "expected": 2 },
    { "id": "ceil", "expr": { "type": "kanonak.org/math/Ceil", "value": { "type": "kanonak.org/transformations/DecimalLiteral", "decimalLiteral": 2.1 } }, "expected": 3 },
    { "id": "round-half-away-positive", "expr": { "type": "kanonak.org/math/Round", "value": { "type": "kanonak.org/transformations/DecimalLiteral", "decimalLiteral": 2.5 } }, "expected": 3 },
    { "id": "round-half-away-negative", "expr": { "type": "kanonak.org/math/Round", "value": { "type": "kanonak.org/transformations/DecimalLiteral", "decimalLiteral": -2.5 } }, "expected": -3 },
    { "id": "round-down", "expr": { "type": "kanonak.org/math/Round", "value": { "type": "kanonak.org/transformations/DecimalLiteral", "decimalLiteral": 2.4 } }, "expected": 2 },
    { "id": "sign-zero", "expr": { "type": "kanonak.org/math/Sign", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 0 } }, "expected": 0 },
    { "id": "sign-negative", "expr": { "type": "kanonak.org/math/Sign", "value": { "type": "kanonak.org/transformations/DecimalLiteral", "decimalLiteral": -3.5 } }, "expected": -1 },
    { "id": "sign-positive", "expr": { "type": "kanonak.org/math/Sign", "value": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 } }, "expected": 1 },

    { "id": "greater-than-true", "expr": { "type": "kanonak.org/transformations/GreaterThan", "compareLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 3 }, "compareRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 } }, "expected": 1 },
    { "id": "less-than-false", "expr": { "type": "kanonak.org/transformations/LessThan", "compareLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 3 }, "compareRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 } }, "expected": 0 },
    { "id": "equals-true", "expr": { "type": "kanonak.org/transformations/Equals", "compareLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 }, "compareRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 } }, "expected": 1 },
    { "id": "gte-equal", "expr": { "type": "kanonak.org/transformations/GreaterThanOrEqual", "compareLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 }, "compareRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 } }, "expected": 1 },
    { "id": "lte-false", "expr": { "type": "kanonak.org/transformations/LessThanOrEqual", "compareLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 3 }, "compareRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 2 } }, "expected": 0 },

    { "id": "and-true", "expr": { "type": "kanonak.org/transformations/And", "operands": [ { "type": "kanonak.org/transformations/BooleanLiteral", "booleanLiteral": true }, { "type": "kanonak.org/transformations/GreaterThan", "compareLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 5 }, "compareRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 1 } } ] }, "expected": 1 },
    { "id": "and-false", "expr": { "type": "kanonak.org/transformations/And", "operands": [ { "type": "kanonak.org/transformations/BooleanLiteral", "booleanLiteral": true }, { "type": "kanonak.org/transformations/BooleanLiteral", "booleanLiteral": false } ] }, "expected": 0 },
    { "id": "and-empty-vacuous-true", "expr": { "type": "kanonak.org/transformations/And", "operands": [] }, "expected": 1 },
    { "id": "or-true", "expr": { "type": "kanonak.org/transformations/Or", "operands": [ { "type": "kanonak.org/transformations/BooleanLiteral", "booleanLiteral": false }, { "type": "kanonak.org/transformations/BooleanLiteral", "booleanLiteral": true } ] }, "expected": 1 },
    { "id": "or-empty-vacuous-false", "expr": { "type": "kanonak.org/transformations/Or", "operands": [] }, "expected": 0 },
    { "id": "not-of-false", "expr": { "type": "kanonak.org/transformations/Not", "operand": { "type": "kanonak.org/transformations/BooleanLiteral", "booleanLiteral": false } }, "expected": 1 },
    { "id": "not-of-true", "expr": { "type": "kanonak.org/transformations/Not", "operand": { "type": "kanonak.org/transformations/BooleanLiteral", "booleanLiteral": true } }, "expected": 0 },

    { "id": "clip-above-upper", "expr": { "type": "kanonak.org/math/Clip", "clipValue": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 15 }, "clipLower": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 0 }, "clipUpper": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 10 } }, "expected": 10 },
    { "id": "clip-below-lower", "expr": { "type": "kanonak.org/math/Clip", "clipValue": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": -5 }, "clipLower": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 0 }, "clipUpper": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 10 } }, "expected": 0 },
    { "id": "clip-within", "expr": { "type": "kanonak.org/math/Clip", "clipValue": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 5 }, "clipLower": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 0 }, "clipUpper": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 10 } }, "expected": 5 },

    { "id": "var-ref", "expr": { "type": "kanonak.org/transformations/VarRef", "varName": "x" }, "env": { "x": 7 }, "expected": 7 },
    { "id": "nested-equation-with-vars", "description": "growth-rate * (1 - population/1000); the dynamics logistic-growth shape", "expr": { "type": "kanonak.org/transformations/Multiply", "arithLeft": { "type": "kanonak.org/transformations/VarRef", "varName": "growth-rate" }, "arithRight": { "type": "kanonak.org/transformations/Subtract", "arithLeft": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 1 }, "arithRight": { "type": "kanonak.org/transformations/Divide", "arithLeft": { "type": "kanonak.org/transformations/VarRef", "varName": "population" }, "arithRight": { "type": "kanonak.org/transformations/IntegerLiteral", "integerLiteral": 1000 } } } }, "env": { "growth-rate": 0.5, "population": 200 }, "expected": 0.4, "tolerance": 1e-12 },
    { "id": "unbound-var-errors", "expr": { "type": "kanonak.org/transformations/VarRef", "varName": "missing" }, "env": {}, "expectError": true }
  ]
}
